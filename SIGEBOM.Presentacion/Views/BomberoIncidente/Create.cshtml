@model SIGEBOM.Negocio.ViewModels.BomberoIncidenteViewModel

@{
    ViewData["Title"] = "Asignar Bombero";
}

<div class="container-fluid">

    <div class="card shadow-sm">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-person-plus-fill"></i>
                Asignar Bombero al Incidente
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <input asp-for="IdIncidente" type="hidden" />
                <input asp-for="IdBombero" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row">

                    <div class="col-md-8">

                        <label class="form-label">
                            Bombero
                        </label>

                        <div class="input-group">

                            <input asp-for="NombreBombero"
                                   class="form-control"
                                   readonly />

                            <button type="button"
                                    class="btn btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalBomberos">

                                <i class="bi bi-search"></i>

                            </button>

                        </div>

                    </div>

                    <div class="col-md-4">

                        <label asp-for="Funcion"
                               class="form-label">
                        </label>

                        <select asp-for="Funcion"
                                class="form-select">

                            <option value="">Seleccione...</option>

                            <option>Jefe de Dotación</option>

                            <option>Conductor</option>

                            <option>Bombero</option>

                            <option>Paramédico</option>

                            <option>Rescatista</option>

                            <option>Operador</option>

                            <option>Supervisor</option>

                        </select>

                        <span asp-validation-for="Funcion"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <div class="mt-3">

                    <label asp-for="Observacion"
                           class="form-label">
                    </label>

                    <textarea asp-for="Observacion"
                              class="form-control"
                              rows="4">
                    </textarea>

                </div>

                <hr />

                <button class="btn btn-danger">

                    <i class="bi bi-save"></i>

                    Guardar

                </button>

                <a asp-action="Index"
                   asp-route-idIncidente="@Model.IdIncidente"
                   class="btn btn-secondary">

                    Cancelar

                </a>

            </form>

        </div>
        <!-- Modal Buscar Bombero -->
        <div class="modal fade"
             id="modalBomberos"
             tabindex="-1"
             aria-hidden="true">

            <div class="modal-dialog modal-xl">

                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">

                        <h5 class="modal-title">
                            <i class="bi bi-search"></i>
                            Buscar Bombero
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        <div class="row mb-3">

                            <div class="col-md-6">

                                <input id="txtBuscarBombero"
                                       class="form-control"
                                       placeholder="Buscar por cédula, nombre o apellido..." />

                            </div>

                        </div>

                        <div class="table-responsive">

                            <table class="table table-hover">

                                <thead class="table-dark">

                                    <tr>

                                        <th>Cédula</th>

                                        <th>Nombre</th>

                                        <th>Apellido</th>

                                        <th>Cargo</th>

                                        <th></th>

                                    </tr>

                                </thead>

                                <tbody id="tablaBomberos">
                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
    @section Scripts{

        <partial name="_ValidationScriptsPartial" />

        <script>

            cargarBomberos("");

            $("#txtBuscarBombero").keyup(function(){

                cargarBomberos($(this).val());

            });

            function cargarBomberos(filtro){

                $.get("/BomberoIncidente/BuscarBomberos",
                {
                    filtro:filtro
                },
                function(data){

                    let filas="";

                    $.each(data,function(i,item){

                        filas+=`
                        <tr>

                            <td>${item.cedula}</td>

                            <td>${item.nombre}</td>

                            <td>${item.apellido}</td>

                            <td>${item.cargo}</td>

                            <td>

                            <button
                            class="btn btn-success btn-sm"
                            onclick="seleccionarBombero(${item.idBombero},
                            '${item.nombre} ${item.apellido}')">

                            Seleccionar

                            </button>

                            </td>

                        </tr>`;
                    });

                    $("#tablaBomberos").html(filas);

                });

            }

            function seleccionarBombero(id,nombre){

                $("#IdBombero").val(id);

                $("#NombreBombero").val(nombre);

                $("#modalBomberos").modal("hide");

            }

        </script>

    }
</div>