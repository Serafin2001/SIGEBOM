@model SIGEBOM.Datos.Models.Turno

@{
    ViewData["Title"] = "Nuevo Turno";
}

<div class="crud-container">

    <!--=========================================
        CABECERA
    =========================================-->

    <div class="crud-header">

        <div>

            <h2>

                Registrar Turno

            </h2>

            <p>

                Complete la información para registrar un nuevo turno.

            </p>

        </div>

    </div>

    <!--=========================================
        FORMULARIO
    =========================================-->

    <div class="crud-card">

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger"></div>

            <div class="row">

                <!-- Nombre -->

                <div class="col-md-6 mb-3">

                    <label asp-for="NombreTurno" class="form-label">

                        Nombre del Turno

                    </label>

                    <input asp-for="NombreTurno"
                           class="form-control"
                           placeholder="Ej.: Turno A" />

                    <span asp-validation-for="NombreTurno"
                          class="text-danger"></span>

                </div>

                <!-- Hora Entrada -->

                <div class="col-md-3 mb-3">

                    <label asp-for="HoraEntrada"
                           class="form-label">

                        Hora de Entrada

                    </label>

                    <input asp-for="HoraEntrada"
                           type="time"
                           class="form-control" />

                    <span asp-validation-for="HoraEntrada"
                          class="text-danger"></span>

                </div>

                <!-- Hora Salida -->

                <div class="col-md-3 mb-3">

                    <label asp-for="HoraSalida"
                           class="form-label">

                        Hora de Salida

                    </label>

                    <input asp-for="HoraSalida"
                           type="time"
                           class="form-control" />

                    <span asp-validation-for="HoraSalida"
                          class="text-danger"></span>

                </div>

                <!-- Descripción -->

                <div class="col-12 mb-4">

                    <label asp-for="Descripcion"
                           class="form-label">

                        Descripción

                    </label>

                    <textarea asp-for="Descripcion"
                              rows="4"
                              class="form-control"
                              placeholder="Descripción del turno..."></textarea>

                    <span asp-validation-for="Descripcion"
                          class="text-danger"></span>

                </div>

            </div>

            <!--=========================================
                BOTONES
            =========================================-->

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left-circle"></i>

                    Regresar

                </a>

                <button type="submit"
                        class="btn btn-danger">

                    <i class="bi bi-check-circle"></i>

                    Guardar

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}