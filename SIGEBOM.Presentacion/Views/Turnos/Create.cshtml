@model SIGEBOM.Datos.Models.Turno

@{
    ViewData["Title"] = "Nuevo Turno";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-danger text-white">

            <h4 class="mb-0">

                <i class="bi bi-clock-history"></i>

                Registrar Turno

            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="NombreTurno" class="form-label"></label>

                        <input asp-for="NombreTurno"
                               class="form-control"
                               placeholder="Ej.: Turno A" />

                        <span asp-validation-for="NombreTurno"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-3 mb-3">

                        <label asp-for="HoraEntrada" class="form-label"></label>

                        <input asp-for="HoraEntrada"
                               type="time"
                               class="form-control" />

                        <span asp-validation-for="HoraEntrada"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-3 mb-3">

                        <label asp-for="HoraSalida" class="form-label"></label>

                        <input asp-for="HoraSalida"
                               type="time"
                               class="form-control" />

                        <span asp-validation-for="HoraSalida"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="mb-4">

                    <label asp-for="Descripcion"
                           class="form-label"></label>

                    <textarea asp-for="Descripcion"
                              rows="4"
                              class="form-control"
                              placeholder="Descripción del turno..."></textarea>

                    <span asp-validation-for="Descripcion"
                          class="text-danger"></span>

                </div>

                <hr />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>

                        Regresar

                    </a>

                    <button type="submit"
                            class="btn btn-danger">

                        <i class="bi bi-save"></i>

                        Guardar

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}