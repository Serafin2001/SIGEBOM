@model SIGEBOM.Datos.Models.Turno

@{
    ViewData["Title"] = "Detalle del Turno";
}

<div class="crud-container">



    <div class="crud-header">

        <div>

            <h2>

                Detalle del Turno

            </h2>

            <p>

                Información completa del turno seleccionado.

            </p>

        </div>

    </div>


    <div class="crud-card">

        <div class="row">

          

            <div class="col-md-6 mb-4">

                <label class="form-label fw-bold">

                    Nombre del Turno

                </label>

                <div class="form-control bg-light">

                    @Model.NombreTurno

                </div>

            </div>

            <!-- Estado -->

            <div class="col-md-6 mb-4">

                <label class="form-label fw-bold">

                    Estado

                </label>

                <div>

                    @if (Model.Estado == "Activo")
                    {
                        <span class="badge bg-success fs-6">

                            Activo

                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">

                            Inactivo

                        </span>
                    }

                </div>

            </div>

            <!-- Hora Entrada -->

            <div class="col-md-6 mb-4">

                <label class="form-label fw-bold">

                    Hora de Entrada

                </label>

                <div class="form-control bg-light">

                    @Model.HoraEntrada.ToString(@"hh\:mm")

                </div>

            </div>

            <!-- Hora Salida -->

            <div class="col-md-6 mb-4">

                <label class="form-label fw-bold">

                    Hora de Salida

                </label>

                <div class="form-control bg-light">

                    @Model.HoraSalida.ToString(@"hh\:mm")

                </div>

            </div>

            <!-- Descripción -->

            <div class="col-12 mb-4">

                <label class="form-label fw-bold">

                    Descripción

                </label>

                <div class="form-control bg-light"
                     style="min-height:120px;">

                    @(string.IsNullOrWhiteSpace(Model.Descripcion)
                                        ? "Sin descripción."
                                        : Model.Descripcion)

                </div>

            </div>

        </div>

        <!--=========================================
            BOTONES
        =========================================-->

        <div class="d-flex justify-content-end gap-2">

            <a asp-action="Index"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left-circle"></i>

                Regresar

            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.IdTurno"
               class="btn btn-warning">

                <i class="bi bi-pencil-square"></i>

                Editar

            </a>

        </div>

    </div>

</div>