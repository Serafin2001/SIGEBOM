@model SIGEBOM.Datos.Models.Turno

@{
    ViewData["Title"] = "Detalles del Turno";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-info text-white">

            <h4 class="mb-0">

                <i class="bi bi-eye"></i>

                Detalles del Turno

            </h4>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-4">

                    <label class="form-label fw-bold">

                        Nombre del Turno

                    </label>

                    <input class="form-control"
                           value="@Model.NombreTurno"
                           readonly />

                </div>

                <div class="col-md-3 mb-4">

                    <label class="form-label fw-bold">

                        Hora de Entrada

                    </label>

                    <input class="form-control"
                           value="@Model.HoraEntrada"
                           readonly />

                </div>

                <div class="col-md-3 mb-4">

                    <label class="form-label fw-bold">

                        Hora de Salida

                    </label>

                    <input class="form-control"
                           value="@Model.HoraSalida"
                           readonly />

                </div>

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">

                    Descripción

                </label>

                <textarea class="form-control"
                          rows="4"
                          readonly>@Model.Descripcion</textarea>

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">

                    Estado

                </label>

                <br />

                @if (Model.Estado == "Activo")
                {
                    <span class="badge bg-success">

                        Activo

                    </span>
                }
                else
                {
                    <span class="badge bg-danger">

                        Inactivo

                    </span>
                }

            </div>

            <hr />

            <div class="d-flex justify-content-between">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>

                    Regresar

                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.IdTurno"
                   class="btn btn-warning">

                    <i class="bi bi-pencil-square"></i>

                    Editar

                </a>

            </div>

        </div>

    </div>

</div>