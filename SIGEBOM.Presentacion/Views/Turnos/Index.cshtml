@model IEnumerable<SIGEBOM.Datos.Models.Turno>

@{
    ViewData["Title"] = "Turnos";
}

<div class="crud-container">

    <!--=========================================
        CABECERA
    =========================================-->

    <div class="crud-header">

        <div>

            <h2>

                Gestión de Turnos

            </h2>

            <p>

                Administración de los turnos del Cuerpo de Bomberos.

            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Nuevo Turno

        </a>

    </div>

    <!--=========================================
        BUSCADOR
    =========================================-->

    <form method="get"
          class="crud-search mb-4">

        <div class="input-group">

            <span class="input-group-text">

                <i class="bi bi-search"></i>

            </span>

            <input type="text"
                   name="buscar"
                   value="@ViewBag.Buscar"
                   class="form-control"
                   placeholder="Buscar turno..." />

            <button class="btn btn-danger">

                Buscar

            </button>

        </div>

    </form>

    <!--=========================================
        MENSAJE
    =========================================-->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">

            @TempData["Success"]

        </div>
    }

    <!--=========================================
        TABLA
    =========================================-->

    <div class="table-responsive">

        <table class="table table-hover align-middle">

            <thead>

                <tr>

                    <th>Turno</th>

                    <th>Entrada</th>

                    <th>Salida</th>

                    <th>Estado</th>

                    <th width="180">

                        Acciones

                    </th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                @item.NombreTurno

                            </td>

                            <td>

                                @item.HoraEntrada.ToString(@"hh\:mm")

                            </td>

                            <td>

                                @item.HoraSalida.ToString(@"hh\:mm")

                            </td>

                            <td>

                                <span class="badge bg-success">

                                    @item.Estado

                                </span>

                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.IdTurno"
                                   class="btn btn-info btn-sm">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.IdTurno"
                                   class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.IdTurno"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button class="btn btn-danger btn-sm"
                                            onclick="return confirm('¿Desea desactivar este turno?')">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="5"
                            class="text-center">

                            No existen turnos registrados.

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>