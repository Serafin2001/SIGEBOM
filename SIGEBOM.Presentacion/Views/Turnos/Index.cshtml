@model IEnumerable<SIGEBOM.Datos.Models.Turno>

@{
    ViewData["Title"] = "Turnos";
}

<div class="container-fluid">

    <div class="card">

        <div class="card-header d-flex justify-content-between align-items-center">

            <div>

                <h3>

                    <i class="bi bi-clock-history"></i>

                    Turnos

                </h3>

                <small class="text-muted">

                    Administración de turnos del cuerpo de bomberos.

                </small>

            </div>

            <a asp-action="Create"
               class="btn btn-danger">

                <i class="bi bi-plus-circle"></i>

                Nuevo Turno

            </a>

        </div>

        <div class="card-body">

            <form method="get"
                  class="row mb-4">

                <div class="col-md-5">

                    <input type="text"
                           name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control"
                           placeholder="Buscar por nombre del turno..." />

                </div>

                <div class="col-auto">

                    <button class="btn btn-primary">

                        <i class="bi bi-search"></i>

                        Buscar

                    </button>

                </div>

            </form>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>

                            <th>Nombre</th>

                            <th>Entrada</th>

                            <th>Salida</th>

                            <th>Estado</th>

                            <th width="180">

                                Acciones

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>

                                        @item.NombreTurno

                                    </td>

                                    <td>

                                        <i class="bi bi-clock me-1 text-danger"></i>

                                        @item.HoraEntrada.ToString(@"hh\:mm")

                                    </td>

                                    <td>

                                        <i class="bi bi-clock me-1 text-danger"></i>

                                        @item.HoraSalida.ToString(@"hh\:mm")

                                    </td>

                                    <td>

                                        <span class="badge bg-success">

                                            @item.Estado

                                        </span>

                                    </td>

                                    <td>

                                        <a asp-action="Details"
                                           asp-route-id="@item.IdTurno"
                                           class="btn btn-info btn-sm">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdTurno"
                                           class="btn btn-warning btn-sm">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <a asp-action="Desactivar"
                                           asp-route-id="@item.IdTurno"
                                           class="btn btn-danger btn-sm">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5"
                                    class="text-center">

                                    No existen turnos registrados.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>