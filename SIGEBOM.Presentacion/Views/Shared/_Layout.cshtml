<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - SIGEBOM</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <!-- Estilos -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/Crud.css"
          asp-append-version="true" />


    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <div class="layout">



        <aside class="sidebar">

            <!-- Logo -->
            <div class="logo">

                <i class="bi bi-fire"></i>

                <div>
                    <small class="text-muted">

                        SIGEBOM

                    </small>
                </div>

            </div>

            <nav class="menu">

                <!-- Dashboard -->

                <a asp-controller="Home"
                   asp-action="Index"
                   class="menu-link">

                    <i class="bi bi-speedometer2"></i>

                    <span>Dashboard</span>

                </a>



                <div class="menu-title">

                    Seguridad

                </div>

                <a class="menu-link"
                   data-bs-toggle="collapse"
                   href="#seguridad">

                    <i class="bi bi-shield-lock"></i>

                    <span>Seguridad</span>

                    <i class="bi bi-chevron-down ms-auto"></i>

                </a>

                <div class="collapse" id="seguridad">

                    <a asp-controller="Usuarios"
                       asp-action="Index"
                       class="submenu">

                        Usuarios

                    </a>

                    <a asp-controller="Roles"
                       asp-action="Index"
                       class="submenu">

                        Roles

                    </a>

                    <a asp-controller="Rangos"
                       asp-action="Index"
                       class="submenu">

                        Rango

                    </a>

                </div>


                <div class="menu-title">

                    Personal

                </div>

                <a class="menu-link"
                   data-bs-toggle="collapse"
                   href="#personal">

                    <i class="bi bi-person-badge"></i>

                    <span>Personal</span>

                    <i class="bi bi-chevron-down ms-auto"></i>

                </a>

                <div class="collapse" id="personal">

                    <a asp-controller="Bomberos"
                       asp-action="Index"
                       class="submenu">

                        Bomberos

                    </a>

                    <a asp-controller="Cargos"
                       asp-action="Index"
                       class="submenu">

                        Cargos

                    </a>

                    <a asp-controller="Turnos"
                       asp-action="Index"
                       class="submenu">

                        Turnos

                    </a>

                    <a asp-controller="Asistencias"
                       asp-action="Index"
                       class="submenu">

                        Asistencias

                    </a>

                    <a asp-controller="Capacitaciones"
                       asp-action="Index"
                       class="submenu">

                        Capacitaciones

                    </a>

                </div>



                <div class="menu-title">

                    Operaciones

                </div>

                <a class="menu-link"
                   data-bs-toggle="collapse"
                   href="#operaciones">

                    <i class="bi bi-fire"></i>

                    <span>Operaciones</span>

                    <i class="bi bi-chevron-down ms-auto"></i>

                </a>

                <div class="collapse" id="operaciones">

                    <a asp-controller="LlamadasEmergencia"
                       asp-action="Index"
                       class="submenu">

                        Llamadas

                    </a>

                    <a asp-controller="Incidentes"
                       asp-action="Index"
                       class="submenu">

                        Incidentes

                    </a>

                    <a asp-controller="TiposIncidentes"
                       asp-action="Index"
                       class="submenu">

                        Tipos de Incidente

                    </a>

                </div>

                <!-- ========================= -->
                <!-- VEHÍCULOS -->
                <!-- ========================= -->

                <div class="menu-title">

                    Vehículos

                </div>

                <a class="menu-link"
                   data-bs-toggle="collapse"
                   href="#vehiculos">

                    <i class="bi bi-truck"></i>

                    <span>Vehículos</span>

                    <i class="bi bi-chevron-down ms-auto"></i>

                </a>

                <div class="collapse" id="vehiculos">

                    <a asp-controller="Vehiculos"
                       asp-action="Index"
                       class="submenu">

                        Vehículos

                    </a>

                    <a asp-controller="Mantenimientos"
                       asp-action="Index"
                       class="submenu">

                        Mantenimientos

                    </a>

                    <a asp-controller="InspeccionesVehiculos"
                       asp-action="Index"
                       class="submenu">

                        Inspecciones

                    </a>

                </div>

                <!-- ========================= -->
                <!-- INVENTARIO -->
                <!-- ========================= -->

                <div class="menu-title">

                    Inventario

                </div>

                <a class="menu-link"
                   data-bs-toggle="collapse"
                   href="#inventario">

                    <i class="bi bi-tools"></i>

                    <span>Inventario</span>

                    <i class="bi bi-chevron-down ms-auto"></i>

                </a>

                <div class="collapse" id="inventario">

                    <a asp-controller="Herramientas"
                       asp-action="Index"
                       class="submenu">

                        Herramientas

                    </a>

                    <a asp-controller="Inventarios"
                       asp-action="Index"
                       class="submenu">

                        Movimientos

                    </a>

                    <a asp-controller="Proveedores"
                       asp-action="Index"
                       class="submenu">

                        Proveedores

                    </a>

                </div>

                <!-- ========================= -->
                <!-- REPORTES -->
                <!-- ========================= -->

                <div class="menu-title">

                    Reportes

                </div>

                <a asp-controller="Reportes"
                   asp-action="Index"
                   class="menu-link">

                    <i class="bi bi-bar-chart-line"></i>

                    <span>Reportes</span>

                </a>

                <!-- ========================= -->
                <!-- CONFIGURACIÓN -->
                <!-- ========================= -->

                <div class="menu-title">

                    Sistema

                </div>

                <a asp-controller="Configuracion"
                   asp-action="Index"
                   class="menu-link">

                    <i class="bi bi-gear"></i>

                    <span>Configuración</span>

                </a>

                <a asp-controller="Cuenta"
                   asp-action="Logout"
                   class="menu-link">

                    <i class="bi bi-box-arrow-right"></i>

                    <span>Cerrar sesión</span>

                </a>

            </nav>

        </aside>



        <div class="main">


            <header class="topbar">



                <div class="topbar-left">

                    <button id="btnMenu" class="btn-menu">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="system-info">

                        <h4 class="mb-0">
                            SIGEBOM
                        </h4>

                        <small>
                            Sistema Integrado de Gestión del Cuerpo de Bomberos
                        </small>

                    </div>

                </div>



                <div class="topbar-center">

                    <div class="fecha-hora">

                        <div class="top-item">

                            <i class="bi bi-calendar3"></i>

                            <span id="fecha"></span>

                        </div>

                        <div class="top-item">

                            <i class="bi bi-clock"></i>

                            <span id="hora"></span>

                        </div>

                    </div>

                </div>



                <div class="topbar-right">

                    <div class="dropdown">

                        <button class="btn-user"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">

                            <div class="user-avatar">

                                <i class="bi bi-person-fill"></i>

                            </div>

                            <div class="user-info">

                                <strong>

                                    @(User.FindFirst("NombreCompleto")?.Value ?? User.Identity?.Name)

                                </strong>

                                <small>

                                    @(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)

                                </small>

                            </div>

                            <i class="bi bi-chevron-down"></i>

                        </button>

                        <ul class="dropdown-menu dropdown-menu-end shadow">

                            <li class="dropdown-header">

                                <strong>

                                    @(User.FindFirst("NombreCompleto")?.Value ?? User.Identity?.Name)

                                </strong>

                                <br />

                                <small class="text-muted">

                                    @(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)

                                </small>

                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>

                                <a class="dropdown-item"
                                   asp-controller="Usuarios"
                                   asp-action="Perfil">

                                    <i class="bi bi-person-circle me-2"></i>

                                    Mi perfil

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-controller="Usuarios"
                                   asp-action="CambiarPassword">

                                    <i class="bi bi-key me-2"></i>

                                    Cambiar contraseña

                                </a>

                            </li>

                            <li>

                                <hr class="dropdown-divider" />

                            </li>

                            <li>

                                <a class="dropdown-item text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    <i class="bi bi-box-arrow-right me-2"></i>

                                    Cerrar sesión

                                </a>

                            </li>

                        </ul>

                    </div>

                </div>

            </header>

            <!-- CONTENIDO -->

            <main class="contenido">

                @RenderBody()

            </main>

            <!-- FOOTER -->

            <footer class="footer">

                © @DateTime.Now.Year SIGEBOM - Sistema de Gestión del Cuerpo de Bomberos

            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/layout.js" asp-append-version="true"></script>

    <script src="~/js/bomberos.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

