<div class="modal fade"
     id="modalBomberos"
     tabindex="-1"
     aria-labelledby="modalBomberosLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">

        <div class="modal-content">

            <!--=========================================
                CABECERA
            ==========================================-->

            <div class="modal-header">

                <h5 class="modal-title"
                    id="modalBomberosLabel">

                    <i class="bi bi-person-badge-fill me-2"></i>

                    Buscar Bomberos

                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <!--=========================================
                CUERPO
            ==========================================-->

            <div class="modal-body">

                <!--==========================
                    PANEL DE FILTROS
                ==========================-->

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-white">

                        <h6 class="mb-0 fw-semibold">

                            <i class="bi bi-funnel-fill text-danger me-2"></i>

                            Filtros de búsqueda

                        </h6>

                    </div>

                    <div class="card-body">

                        <div class="row g-3">

                            <!-- CÉDULA -->

                            <div class="col-lg-3 col-md-6">

                                <label class="form-label">

                                    Cédula

                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">

                                        <i class="bi bi-credit-card"></i>

                                    </span>

                                    <input type="text"
                                           id="txtCedula"
                                           class="form-control"
                                           placeholder="402-0000000-0">

                                </div>

                            </div>

                            <!-- NOMBRE -->

                            <div class="col-lg-3 col-md-6">

                                <label class="form-label">

                                    Nombre

                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">

                                        <i class="bi bi-person"></i>

                                    </span>

                                    <input type="text"
                                           id="txtNombre"
                                           class="form-control"
                                           placeholder="Nombre">

                                </div>

                            </div>

                            <!-- APELLIDO -->

                            <div class="col-lg-3 col-md-6">

                                <label class="form-label">

                                    Apellido

                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">

                                        <i class="bi bi-person"></i>

                                    </span>

                                    <input type="text"
                                           id="txtApellido"
                                           class="form-control"
                                           placeholder="Apellido">

                                </div>

                            </div>

                            <!-- RANGO -->

                            <div class="col-lg-3 col-md-6">

                                <label class="form-label">

                                    Rango

                                </label>

                                <select id="cmbRango"
                                        class="form-select">

                                    <option value="">

                                        Todos

                                    </option>

                                </select>

                            </div>

                        </div>

                        <div class="row mt-4">

                            <div class="col text-end">

                                <button type="button"
                                        id="btnLimpiarBusqueda"
                                        class="btn btn-outline-secondary">

                                    <i class="bi bi-arrow-clockwise"></i>

                                    Limpiar

                                </button>

                                <button type="button"
                                        id="btnBuscarBombero"
                                        class="btn btn-danger">

                                    <i class="bi bi-search"></i>

                                    Buscar

                                </button>

                            </div>

                        </div>

                    </div>

                </div>

                <!--==========================
                    TABLA
                ==========================-->

                <div id="contenidoBomberos">

                    <div class="text-center py-5">

                        <div class="spinner-border text-danger"
                             role="status">
                        </div>

                        <p class="mt-3 text-muted">

                            Cargando bomberos...

                        </p>

                    </div>

                </div>

            </div>

            <!--=========================================
                FOOTER
            ==========================================-->

            <div class="modal-footer">

                <div class="me-auto">

                    <small class="text-muted">

                        Seleccione un bombero y presione
                        <strong>Seleccionar</strong>.

                    </small>

                </div>

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    <i class="bi bi-x-circle me-1"></i>

                    Cerrar

                </button>

                <button type="button"
                        id="btnAceptarBomberos"
                        class="btn btn-danger">

                    <i class="bi bi-check-circle me-1"></i>

                    Aceptar

                </button>

            </div>

        </div>

    </div>

</div>