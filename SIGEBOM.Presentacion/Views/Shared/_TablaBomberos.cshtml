@model IEnumerable<SIGEBOM.Datos.Models.Bombero>

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h6 class="mb-0 fw-semibold">

                    <i class="bi bi-people-fill text-danger me-2"></i>

                    Bomberos encontrados

                </h6>

            </div>

            <span class="badge bg-danger">

                @Model.Count() Registro(s)

            </span>

        </div>

    </div>

    <div class="table-responsive">

        <table class="table table-hover align-middle mb-0">

            <thead>

                <tr>

                    <th style="width:150px">

                        Cédula

                    </th>

                    <th>

                        Nombre Completo

                    </th>

                    <th style="width:170px">

                        Rango

                    </th>

                    <th style="width:170px">

                        Cargo

                    </th>

                    <th style="width:120px"
                        class="text-center">

                        Estado

                    </th>

                    <th style="width:120px"
                        class="text-center">

                        Acción

                    </th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                <strong>

                                    @item.Cedula

                                </strong>

                            </td>

                            <td>

                                <div class="fw-semibold">

                                    @item.NombreCompleto

                                </div>

                                <small class="text-muted">

                                    ID #@item.IdBombero

                                </small>

                            </td>

                            <td>

                                @(item.Rango?.NombreRango ?? "-")

                            </td>

                            <td>

                                @(item.Cargo?.NombreCargo ?? "Sin cargo")

                            </td>

                            <td class="text-center">

                                @if (item.Estado == "Activo")
                                {
                                    <span class="badge rounded-pill bg-success">

                                        Activo

                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger">

                                        @item.Estado

                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <button type="button"
                                        class="btn btn-danger btn-sm seleccionarBombero"
                                        data-id="@item.IdBombero"
                                        data-nombre="@item.NombreCompleto"
                                        data-cedula="@item.Cedula">

                                    <i class="bi bi-check2-circle me-1"></i>

                                    Seleccionar

                                </button>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="6"
                            class="text-center py-5">

                            <i class="bi bi-search fs-1 text-secondary"></i>

                            <h5 class="mt-3">

                                No se encontraron bomberos

                            </h5>

                            <p class="text-muted">

                                Cambie los filtros de búsqueda e intente nuevamente.

                            </p>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <div class="card-footer bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <small class="text-muted">

                Mostrando

                <strong>

                    @Model.Count()

                </strong>

                registro(s)

            </small>

            <button class="btn btn-outline-danger btn-sm"
                    onclick="cargarBomberos('')">

                <i class="bi bi-arrow-repeat me-1"></i>

                Actualizar

            </button>

        </div>

    </div>

</div>