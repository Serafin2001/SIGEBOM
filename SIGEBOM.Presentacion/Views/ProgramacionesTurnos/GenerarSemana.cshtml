@model SIGEBOM.Negocio.ViewModels.GenerarSemanaViewModel

<div class="card shadow-sm">

    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">
            Generar Programación Semanal
        </h4>
    </div>

    <div class="card-body">

        <form asp-action="GenerarSemana" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">

                <label asp-for="FechaInicio"
                       class="form-label">
                </label>

                <input asp-for="FechaInicio"
                       class="form-control" />

                <span asp-validation-for="FechaInicio"
                      class="text-danger">
                </span>

            </div>

            <button type="submit"
                    class="btn btn-success">

                <i class="bi bi-calendar-week"></i>

                Generar Semana

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Cancelar

            </a>

        </form>

    </div>

</div>