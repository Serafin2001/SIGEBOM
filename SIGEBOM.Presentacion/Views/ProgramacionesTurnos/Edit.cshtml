@model SIGEBOM.Negocio.ViewModels.ProgramacionTurnoViewModel

@{
    ViewData["Title"] = "Editar Programación";
}

<div class="crud-container">

    <div class="crud-header">

        <div>

            <h2>Editar Programación de Turno</h2>

            <p>Actualice la información de la programación.</p>

        </div>

    </div>

    <div class="crud-card">

        <form asp-action="Edit" method="post">

            @Html.AntiForgeryToken()

            <input asp-for="IdProgramacionTurno" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">

                    <label asp-for="Fecha" class="form-label"></label>

                    <input asp-for="Fecha"
                           type="date"
                           class="form-control" />

                </div>

                <div class="col-md-4 mb-3">

                    <label class="form-label">

                        Turno

                    </label>

                    <select asp-for="IdTurno"
                            class="form-select">

                        @foreach (var turno in Model.Turnos)
                        {
                            <option value="@turno.IdTurno">

                                @turno.NombreTurno

                            </option>
                        }

                    </select>

                </div>

            </div>

            <hr />

            <h5>Encargado</h5>

            <div class="row">

                <div class="col-md-2">

                    <input asp-for="IdEncargado"
                           id="IdEncargado"
                           type="hidden" />

                    <label>Cédula</label>

                    <input id="CedulaEncargado"
                           class="form-control"
                           value="@Model.CedulaEncargado"
                           readonly />

                </div>

                <div class="col-md-7">

                    <label>Nombre</label>

                    <input id="NombreEncargado"
                           class="form-control"
                           value="@Model.NombreEncargado"
                           readonly />

                </div>

                <div class="col-md-3 d-grid">

                    <label>&nbsp;</label>

                    <button type="button"
                            class="btn btn-danger"
                            onclick="abrirModalBomberos('IdEncargado',
                                                         'NombreEncargado',
                                                         'CedulaEncargado')">

                        <i class="bi bi-search"></i>

                        Buscar

                    </button>

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h5>Bomberos Asignados</h5>

                <button type="button"
                        id="btnAgregarBomberos"
                        class="btn btn-primary">

                    <i class="bi bi-plus-circle"></i>

                    Agregar Bomberos

                </button>

            </div>

            <table class="table table-bordered">

                <thead>

                    <tr>

                        <th>Cédula</th>

                        <th>Nombre</th>

                        <th width="80"></th>

                    </tr>

                </thead>

                <tbody id="tablaSeleccionados">

                    @foreach (var bombero in Model.Bomberos)
                    {
                        <tr id="bombero_@bombero.IdBombero">

                            <td>

                                @bombero.Cedula

                                <input type="hidden"
                                       name="BomberosSeleccionados"
                                       value="@bombero.IdBombero" />

                            </td>

                            <td>

                                @bombero.NombreCompleto

                            </td>

                            <td class="text-center">

                                <button type="button"
                                        class="btn btn-danger btn-sm eliminarBombero">

                                    <i class="bi bi-trash"></i>

                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <div class="mb-4">

                <label asp-for="Observacion"
                       class="form-label"></label>

                <textarea asp-for="Observacion"
                          rows="4"
                          class="form-control">
                </textarea>

            </div>

            <div class="text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Regresar

                </a>

                <button class="btn btn-warning">

                    Guardar Cambios

                </button>

            </div>

        </form>

    </div>

</div>

<partial name="_ModalBomberos" />

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/modalBomberos.js"></script>

    <script>

                $("#btnAgregarBomberos").click(function () {

                    abrirModalBomberosMultiple(function (bomberos) {

                        bomberos.forEach(function (b) {

                            if ($("#bombero_" + b.id).length)
                                return;

                            let fila = `
        <tr id="bombero_${b.id}">

        <td>

        ${b.cedula}

        <input type="hidden"
               name="BomberosSeleccionados"
               value="${b.id}" />

        </td>

        <td>

        ${b.nombre}

        </td>

        <td class="text-center">

        <button type="button"
                class="btn btn-danger btn-sm eliminarBombero">

        <i class="bi bi-trash"></i>

        </button>

        </td>

        </tr>`;

                            $("#tablaSeleccionados").append(fila);

                        });

                    });

                });

                $(document).on("click",
                    ".eliminarBombero",
                    function () {

                        $(this).closest("tr").remove();

                    });

    </script>

}
