@model IEnumerable<SIGEBOM.Datos.Models.ProgramacionTurno>

@{
    ViewData["Title"] = "Programación de Turnos";
}

<div class="crud-container">

    <div class="crud-header d-flex justify-content-between align-items-center">

        <div>

            <h2>Programación de Turnos</h2>

            <p>
                Administre las programaciones de turnos del personal.
            </p>

        </div>

        <a asp-action="Create" class="btn btn-danger">
            <i class="bi bi-plus-circle"></i>
            Nueva Programación
        </a>

    </div>

    <div class="crud-card">

        <form asp-action="Index" method="get" class="row mb-4">

            <div class="col-md-3">

                <label class="form-label">Fecha</label>

                <input type="date"
                       name="fecha"
                       value="@ViewBag.Fecha"
                       class="form-control" />

            </div>

            <div class="col-md-2 d-grid align-self-end">

                <button class="btn btn-primary">

                    <i class="bi bi-search"></i>

                    Buscar

                </button>

            </div>

        </form>

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">

                <tr>

                    <th>Fecha</th>

                    <th>Turno</th>

                    <th>Encargado</th>

                    <th>Estado</th>

                    <th width="220">Acciones</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Fecha.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.Turno?.NombreTurno
                            </td>

                            <td>
                                @item.Encargado?.NombreCompleto
                            </td>

                            <td>

                                @if (item.Estado == "Programado")
                                {
                                    <span class="badge bg-primary">
                                        @item.Estado
                                    </span>
                                }
                                else if (item.Estado == "En Curso")
                                {
                                    <span class="badge bg-warning text-dark">
                                        @item.Estado
                                    </span>
                                }
                                else if (item.Estado == "Finalizado")
                                {
                                    <span class="badge bg-success">
                                        @item.Estado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        @item.Estado
                                    </span>
                                }

                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.IdProgramacionTurno"
                                   class="btn btn-info btn-sm">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.IdProgramacionTurno"
                                   class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.IdProgramacionTurno"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('¿Desea cancelar esta programación?');">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </form>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="5" class="text-center">

                            No existen programaciones registradas.

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>