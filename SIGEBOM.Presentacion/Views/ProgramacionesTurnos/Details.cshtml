@model SIGEBOM.Negocio.ViewModels.ProgramacionTurnoDetailsViewModel

@{
    ViewData["Title"] = "Detalle de Programación";
}

<div class="container-fluid">

    <!--=========================================
        TÍTULO
    ==========================================-->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-danger">

                <i class="bi bi-calendar-check-fill me-2"></i>

                Detalle de Programación de Turno

            </h2>

            <p class="text-muted mb-0">

                Información general y bomberos asignados.

            </p>

        </div>

        <div>

            <a asp-action="Edit"
               asp-route-id="@Model.Programacion.IdProgramacionTurno"
               class="btn btn-warning">

                <i class="bi bi-pencil-square"></i>

                Editar

            </a>

            <a asp-action="Index"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left-circle"></i>

                Volver

            </a>

        </div>

    </div>

    <!--=========================================
        INFORMACIÓN GENERAL
    ==========================================-->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-danger text-white">

            <h5 class="mb-0">

                <i class="bi bi-info-circle-fill me-2"></i>

                Información General

            </h5>

        </div>

        <div class="card-body">

            <div class="row g-4">

                <div class="col-md-3">

                    <label class="fw-bold text-muted">

                        Fecha

                    </label>

                    <div>

                        @Model.Programacion.Fecha.ToString("dd/MM/yyyy")

                    </div>

                </div>

                <div class="col-md-3">

                    <label class="fw-bold text-muted">

                        Turno

                    </label>

                    <div>

                        @Model.Programacion.Turno.NombreTurno

                    </div>

                </div>

                <div class="col-md-3">

                    <label class="fw-bold text-muted">

                        Encargado

                    </label>

                    <div>

                        @Model.Programacion.Encargado.NombreCompleto

                    </div>

                </div>

                <div class="col-md-3">

                    <label class="fw-bold text-muted">

                        Estado

                    </label>

                    <div>

                        @if (Model.Programacion.Estado == "Programado")
                        {
                            <span class="badge bg-success">

                                Programado

                            </span>
                        }
                        else if (Model.Programacion.Estado == "En Curso")
                        {
                            <span class="badge bg-warning text-dark">

                                En Curso

                            </span>
                        }
                        else if (Model.Programacion.Estado == "Finalizado")
                        {
                            <span class="badge bg-primary">

                                Finalizado

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">

                                @Model.Programacion.Estado

                            </span>
                        }

                    </div>

                </div>

            </div>

            <hr />

            <div>

                <label class="fw-bold text-muted">

                    Observación

                </label>

                <div>

                    @(string.IsNullOrWhiteSpace(Model.Programacion.Observacion)
                                        ? "Sin observaciones."
                                        : Model.Programacion.Observacion)

                </div>

            </div>

        </div>

    </div>

    <!--=========================================
        BOMBEROS
    ==========================================-->

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">

            <div class="d-flex justify-content-between align-items-center">

                <h5 class="mb-0">

                    <i class="bi bi-people-fill text-danger me-2"></i>

                    Bomberos Asignados

                </h5>

                <span class="badge bg-danger">

                    @Model.Bomberos.Count Bomberos

                </span>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Cédula</th>

                        <th>Nombre Completo</th>

                        <th>Rango</th>

                        <th>Cargo</th>

                        <th>Estado</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Bomberos.Any())
                    {
                        foreach (var item in Model.Bomberos)
                        {
                            <tr>

                                <td>

                                    @item.Bombero.Cedula

                                </td>

                                <td>

                                    <strong>

                                        @item.Bombero.NombreCompleto

                                    </strong>

                                </td>

                                <td>

                                    @item.Bombero.Rango?.NombreRango

                                </td>

                                <td>

                                    @(item.Bombero.Cargo?.NombreCargo ?? "Sin cargo")

                                </td>

                                <td>

                                    @if (item.Estado == "Asignado")
                                    {
                                        <span class="badge bg-success">

                                            Asignado

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">

                                            @item.Estado

                                        </span>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="5"
                                class="text-center py-5">

                                <i class="bi bi-person-x fs-1 text-secondary"></i>

                                <p class="mt-3 mb-0">

                                    No existen bomberos asignados.

                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}