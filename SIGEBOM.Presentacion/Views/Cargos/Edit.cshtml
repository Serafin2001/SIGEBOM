@model SIGEBOM.Datos.Models.Cargo

@{
    ViewData["Title"] = "Editar Cargo";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-warning">

            <h4 class="mb-0">

                Editar Cargo

            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input asp-for="IdCargo" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">

                    <label asp-for="NombreCargo"
                           class="form-label"></label>

                    <input asp-for="NombreCargo"
                           class="form-control" />

                    <span asp-validation-for="NombreCargo"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Descripcion"
                           class="form-label"></label>

                    <textarea asp-for="Descripcion"
                              rows="4"
                              class="form-control"></textarea>

                    <span asp-validation-for="Descripcion"
                          class="text-danger"></span>

                </div>

                <hr />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>

                        Regresar

                    </a>

                    <button class="btn btn-warning">

                        <i class="bi bi-save"></i>

                        Guardar Cambios

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}