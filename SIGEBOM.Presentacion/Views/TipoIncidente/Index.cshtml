@model IEnumerable<SIGEBOM.Datos.Models.TipoIncidente>

@{
    ViewData["Title"] = "Tipos de Incidentes";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Tipos de Incidentes
            </h2>

            <p class="text-muted">
                Administración de los tipos de incidentes del sistema.
            </p>

        </div>

        <a asp-action="Create" class="btn btn-danger">

            <i class="bi bi-plus-circle"></i>

            Nuevo Tipo

        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th width="80">ID</th>

                            <th>Nombre</th>

                           

                            <th width="120">Estado</th>

                            <th width="180" class="text-center">
                                Acciones
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.IdTipoIncidente
                                    </td>

                                    <td>
                                        @item.Nombre
                                    </td>


                                    <td>

                                        @if (item.Estado == "Activo")
                                        {
                                            <span class="badge bg-success">
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Inactivo
                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Details"
                                           asp-route-id="@item.IdTipoIncidente"
                                           class="btn btn-info btn-sm"
                                           title="Ver">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdTipoIncidente"
                                           class="btn btn-warning btn-sm"
                                           title="Editar">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        @if (item.Estado == "Activo")
                                        {
                                            <button type="button"
                                                    class="btn btn-secondary btn-sm btnEstado"
                                                    data-id="@item.IdTipoIncidente"
                                                    data-estado="Inactivo"
                                                    title="Inactivar">

                                                <i class="bi bi-toggle-off"></i>

                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-success btn-sm btnEstado"
                                                    data-id="@item.IdTipoIncidente"
                                                    data-estado="Activo"
                                                    title="Activar">

                                                <i class="bi bi-toggle-on"></i>

                                            </button>
                                        }

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5" class="text-center py-5">

                                    <i class="bi bi-folder-x display-4 text-secondary"></i>

                                    <p class="mt-3">

                                        No existen tipos de incidentes registrados.

                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        $(function(){

            $(".btnEstado").click(function(){

                let id=$(this).data("id");
                let estado=$(this).data("estado");

                $.post('@Url.Action("CambiarEstado")',
                {
                    id:id,
                    estado:estado
                },
                function(){

                    location.reload();

                });

            });

        });

    </script>

}