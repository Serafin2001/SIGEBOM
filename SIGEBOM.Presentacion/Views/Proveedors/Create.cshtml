@model SIGEBOM.Datos.Models.Proveedor

@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                Registrar Proveedor
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre"
                               class="form-control"
                               placeholder="Nombre del proveedor" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Telefono" class="form-label"></label>
                        <input asp-for="Telefono"
                               class="form-control"
                               maxlength="10"
                               placeholder="8090000000" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Estado" class="form-label"></label>
                        <select asp-for="Estado" class="form-select">
                            <option value="">Seleccione...</option>
                            <option>Activo</option>
                            <option>Inactivo</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo"
                               type="email"
                               class="form-control"
                               placeholder="correo@empresa.com" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Direccion" class="form-label"></label>
                        <input asp-for="Direccion"
                               class="form-control"
                               placeholder="Dirección del proveedor" />
                        <span asp-validation-for="Direccion" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label asp-for="Fecha" class="form-label"></label>
                        <input asp-for="Fecha"
                               type="date"
                               class="form-control" />
                        <span asp-validation-for="Fecha" class="text-danger"></span>
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Regresar
                    </a>

                    <button type="submit" class="btn btn-danger" id="btnGuardar">
                        <i class="bi bi-save"></i>
                        Guardar
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        $('form').submit(function () {
            $('#btnGuardar')
                .prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm"></span> Guardando...');
        });
    </script>

}