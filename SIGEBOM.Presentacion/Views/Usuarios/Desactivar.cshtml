@model SIGEBOM.Datos.Models.Usuario

@{
    ViewData["Title"] = "Desactivar Usuario";
}

<div class="container">

    <div class="card shadow">

        <div class="card-header bg-danger text-white">

            <h4>

                Eliminar Usuario

            </h4>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                ¿Está seguro que desea desactivar este usuario?

            </div>

            <dl class="row">

                <dt class="col-sm-3">

                    Usuario

                </dt>

                <dd class="col-sm-9">

                    @Model.NombreUsuario

                </dd>

                <dt class="col-sm-3">

                    Bombero

                </dt>

                <dd class="col-sm-9">

                    @Model.Bombero.NombreCompleto

                </dd>

                <dt class="col-sm-3">

                    Rol

                </dt>

                <dd class="col-sm-9">

                    @Model.Rol.NombreRol

                </dd>

            </dl>

        </div>

        <div class="card-footer">

            <form asp-action="Desactivar">

                <input asp-for="IdUsuario"
                       type="hidden" />

                <button class="btn btn-danger">

                    Eliminar

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancelar

                </a>

            </form>

        </div>

    </div>

</div>