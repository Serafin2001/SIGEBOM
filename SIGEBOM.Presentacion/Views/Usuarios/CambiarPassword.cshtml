@model SIGEBOM.Negocio.ViewModels.CambiarPasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-warning text-dark">

            <h4 class="mb-0">

                <i class="bi bi-key-fill"></i>

                Cambiar Contraseña

            </h4>

        </div>

        <div class="card-body">

            <form asp-action="CambiarPassword" method="post">

                @Html.AntiForgeryToken()

                <input asp-for="IdUsuario" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-4">

                    <label class="form-label">

                        Usuario

                    </label>

                    <input asp-for="NombreUsuario"
                           class="form-control"
                           readonly />

                </div>

                <div class="mb-4">

                    <label asp-for="NuevaContraseña"
                           class="form-label"></label>

                    <input asp-for="NuevaContraseña"
                           type="password"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="NuevaContraseña"
                          class="text-danger"></span>

                </div>

                <div class="mb-4">

                    <label asp-for="ConfirmarContraseña"
                           class="form-label"></label>

                    <input asp-for="ConfirmarContraseña"
                           type="password"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="ConfirmarContraseña"
                          class="text-danger"></span>

                </div>

                <hr />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>

                        Regresar

                    </a>

                    <button type="submit"
                            class="btn btn-warning">

                        <i class="bi bi-key-fill"></i>

                        Cambiar Contraseña

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}