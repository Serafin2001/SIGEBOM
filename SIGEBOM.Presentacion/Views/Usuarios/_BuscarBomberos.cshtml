@model IEnumerable<SIGEBOM.Datos.Models.Bombero>

<table class="table table-hover table-bordered align-middle">

    <thead class="table-dark">

        <tr>

            <th>Rango</th>

            <th>Cédula</th>

            <th>Nombre</th>

            <th width="120"></th>

        </tr>

    </thead>

    <tbody>

        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>

                    <td>

                        @item.Rango.NombreRango

                    </td>

                    <td>

                        @item.Cedula

                    </td>

                    <td>

                        @item.NombreCompleto

                    </td>

                    <td>

                        <button type="button"
                                class="btn btn-success btn-sm seleccionarBombero"
                                data-id="@item.IdBombero"
                                data-nombre="@item.NombreCompleto">

                            Seleccionar

                        </button>

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>

                <td colspan="4"
                    class="text-center">

                    No hay bomberos disponibles.

                </td>

            </tr>
        }

    </tbody>

</table>