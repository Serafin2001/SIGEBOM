@model IEnumerable<SIGEBOM.Datos.Models.LlamadaEmergencia>

@{
    ViewData["Title"] = "Llamadas de Emergencia";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-danger">
                <i class="bi bi-telephone-fill me-2"></i>
                Llamadas de Emergencia
            </h2>

            <p class="text-muted">
                Administración de llamadas recibidas.
            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-danger">

            <i class="bi bi-plus-circle"></i>

            Nueva Llamada

        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-nowrap">

                    <thead class="table-light">

                        <tr>

                            <th style="width:140px;">Fecha</th>

                            <th style="width:180px;">Reportante</th>

                            

                            <th style="width:130px;">Estado</th>

                            <th style="width:220px;" class="text-center">
                                Acciones
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.FechaHora.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td>
                                        @item.NombreReportante
                                    </td>

                                    <td>

                                        @switch (item.Estado)
                                        {
                                            case "Pendiente":
                                                <span class="badge bg-warning text-dark">
                                                    Pendiente
                                                </span>
                                                break;

                                            case "En Atención":
                                                <span class="badge bg-primary">
                                                    En Atención
                                                </span>
                                                break;

                                            case "Atendida":
                                                <span class="badge bg-success">
                                                    Atendida
                                                </span>
                                                break;

                                            default:
                                                <span class="badge bg-danger">
                                                    Cancelada
                                                </span>
                                                break;
                                        }

                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Details"
                                           asp-route-id="@item.IdLlamada"
                                           class="btn btn-info btn-sm"
                                           title="Ver">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdLlamada"
                                           class="btn btn-warning btn-sm"
                                           title="Editar">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        @if (item.Estado == "Pendiente")
                                        {
                                            <form asp-action="CambiarEstado"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@item.IdLlamada" />

                                                <input type="hidden"
                                                       name="estado"
                                                       value="En Atención" />

                                                <button type="submit"
                                                        class="btn btn-primary btn-sm"
                                                        title="Atender">

                                                    <i class="bi bi-truck"></i>

                                                </button>

                                            </form>
                                        }

                                        @if (item.Estado == "En Atención")
                                        {
                                            <a asp-controller="Incidente"
                                               asp-action="Create"
                                               asp-route-idLlamada="@item.IdLlamada"
                                               class="btn btn-success btn-sm"
                                               title="Registrar Incidente">

                                                <i class="bi bi-fire"></i>

                                            </a>
                                        }

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7"
                                    class="text-center py-5">

                                    <i class="bi bi-telephone-x fs-1 text-secondary"></i>

                                    <p class="mt-3 mb-0">

                                        No existen llamadas registradas.

                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>