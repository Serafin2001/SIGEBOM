@model SIGEBOM.Negocio.ViewModels.LlamadaEmergenciaViewModel

@{
    ViewData["Title"] = "Registrar Llamada de Emergencia";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-danger">

                <i class="bi bi-telephone-plus-fill me-2"></i>

                Registrar Llamada de Emergencia

            </h2>

            <p class="text-muted">

                Complete la información reportada por el ciudadano.

            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left-circle"></i>

            Volver

        </a>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="NombreReportante"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="NombreReportante"
                               class="form-control"
                               placeholder="Nombre del reportante" />

                        <span asp-validation-for="NombreReportante"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="Telefono"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Telefono"
                               class="form-control"
                               placeholder="809-000-0000" />

                        <span asp-validation-for="Telefono"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-8 mb-3">

                        <label asp-for="Direccion"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Direccion"
                               class="form-control"
                               placeholder="Dirección de la emergencia" />

                        <span asp-validation-for="Direccion"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label fw-bold">

                            Tipo de Incidente

                        </label>

                        <select asp-for="IdTipoIncidente"
                                asp-items="ViewBag.TiposIncidentes"
                                class="form-select">

                            <option value="">

                                -- Seleccione --

                            </option>

                        </select>

                        <span asp-validation-for="IdTipoIncidente"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label asp-for="FechaHora"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="FechaHora"
                               class="form-control"
                               readonly />

                    </div>

                    <div class="col-md-8 mb-3">

                        <label asp-for="Observacion"
                               class="form-label fw-bold">
                        </label>

                        <textarea asp-for="Observacion"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Observaciones de la llamada">
                        </textarea>

                    </div>

                </div>

                <hr />

                <div class="text-end">

                    <button type="submit"
                            class="btn btn-danger">

                        <i class="bi bi-save"></i>

                        Guardar

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}