@model SIGEBOM.Datos.Models.Rol

@{
    ViewData["Title"] = "Editar Rol";
}

<div class="container">

    <div class="card shadow">

        <div class="card-header bg-warning text-dark">

            <h4 class="mb-0">
                Editar Rol
            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <input type="hidden" asp-for="IdRol" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">

                    <label asp-for="NombreRol" class="form-label"></label>

                    <input asp-for="NombreRol"
                           class="form-control"
                           placeholder="Nombre del rol" />

                    <span asp-validation-for="NombreRol" class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Estado" class="form-label"></label>

                    <input asp-for="Estado"
                           class="form-control"
                           readonly />

                </div>

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>

                        Regresar

                    </a>

                    <button type="submit"
                            class="btn btn-warning">

                        <i class="bi bi-save"></i>

                        Actualizar

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}